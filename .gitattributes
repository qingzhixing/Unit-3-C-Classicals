# Force LF line endings for all text files (cross-platform consistency)
* text=auto eol=lf

# Source files
*.c    text eol=lf
*.h    text eol=lf
*.py   text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.sh   text eol=lf

# Binary files
*.jpg  binary
*.png  binary
*.out  binary
*.o    binary
*.exe  binary
